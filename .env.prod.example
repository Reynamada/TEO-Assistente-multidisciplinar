# ================================================================
# TEO — Variáveis de Produção
# ================================================================
# Copie para .env antes do deploy: cp .env.prod.example .env
# NUNCA commite o .env real no Git!

# --- PostgreSQL (use senha forte em produção) ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=teo_db
POSTGRES_USER=teo_user
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_64_CHARS_MINIMO
DATABASE_URL=postgresql://teo_user:TROQUE_POR_SENHA_FORTE_64_CHARS_MINIMO@db:5432/teo_db

# --- FastAPI (gerar com: openssl rand -hex 32) ---
SECRET_KEY=GERE_COM_openssl_rand_hex_32_E_COLE_AQUI
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Groq API (gratuita: https://console.groq.com/) ---
GROQ_API_KEY=gsk_sua_chave_groq_aqui
GROQ_MODEL=llama-3.1-70b-versatile

# --- Ollama (fallback local — deixe vazio se não usar) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# --- Twilio WhatsApp Business ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=seu_auth_token_aqui
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# URL pública do servidor (seu domínio com HTTPS)
TWILIO_WEBHOOK_URL=https://teo.suaclinica.com.br/api/v1/whatsapp/webhook

# --- Clínica ---
CLINIC_NAME=Clínica TEO Neurodesenvolvimento
CLINIC_PHONE=+55 11 99999-9999
CLINIC_EMAIL=contato@suaclinica.com.br

# --- Diretórios (dentro do container) ---
REPORTS_DIR=/app/reports
TEMPLATES_DIR=/app/templates

# --- Scheduler ---
LAUDO_ALERT_DAYS=150
CRON_RUN_TIME=08:00

# --- Ambiente PRODUÇÃO ---
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING

# --- NGINX / SSL ---
# Domínio principal do sistema (sem https://)
DOMAIN=teo.suaclinica.com.br
# E-mail para notificações do Let's Encrypt
LETSENCRYPT_EMAIL=admin@suaclinica.com.br
